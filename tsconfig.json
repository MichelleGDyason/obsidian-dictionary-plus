{
  "compilerOptions": {
    "types": ["node", "svelte"],
    "baseUrl": ".",
    "module": "ESNext",
    "target": "ES2020",
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noEmit": true,
    "importHelpers": true,
    "paths": {
      "src": ["src/*"]
    },
    "lib": [
      "dom",
      "es2020"
    ]
  },
  "include": ["src/**/*.ts", "src/**/*.svelte", "tests/**/*.ts"],
  "exclude": ["node_modules", "api"]
}
